generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
 image       String?  // Optional image URL
  stock       Int      @default(10) // Default stock level
  category    String
  aiTags      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id        String   @id @default(cuid())
  total     Float
  status    String   @default("PENDING")
  items     Json
  createdAt DateTime @default(now())
}
